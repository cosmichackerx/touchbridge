<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon />
    <AssemblyName>TouchBridge</AssemblyName>
    <RootNamespace>TouchBridge.Desktop</RootNamespace>
    <Version>1.0.0</Version>
    <Description>TouchBridge Desktop — wireless touchpad server for Windows</Description>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

</Project>
