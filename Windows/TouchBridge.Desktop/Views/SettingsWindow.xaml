<Window x:Class="TouchBridge.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TouchBridge Settings"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Topmost="True">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="BorderBrush" Value="#4F8EF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E8E8F0"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F8EF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#3A3A4C"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#4F8EF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Remote access &amp; encryption" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="Share the remote address + password with anyone. Traffic is end-to-end encrypted (AES-256) with a key derived from the password — the relay never sees your input."
                   TextWrapping="Wrap" Foreground="#A0A0B4" FontSize="11" Margin="0,0,0,16"/>

        <TextBlock Text="Remote domain" Margin="0,0,0,4"/>
        <TextBox x:Name="DomainBox" Margin="0,0,0,4"/>
        <TextBlock Text="Your permanent ngrok address (e.g. your-name.ngrok-free.dev). Auth is configured once via ngrok on this PC."
                   TextWrapping="Wrap" Foreground="#A0A0B4" FontSize="11" Margin="0,0,0,16"/>

        <TextBlock Text="Password (shared secret)" Margin="0,0,0,4"/>
        <TextBox x:Name="PasswordBox" Margin="0,0,0,4"/>
        <TextBlock Text="Leave empty to keep using the random PIN shown on the bar. This password is the encryption key — share it privately."
                   TextWrapping="Wrap" Foreground="#A0A0B4" FontSize="11" Margin="0,0,0,20"/>

        <TextBlock Text="Phone keyboard skin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="Choose the on-screen keyboard theme shown on the connected phone. Applied instantly when you save."
                   TextWrapping="Wrap" Foreground="#A0A0B4" FontSize="11" Margin="0,0,0,8"/>
        <ComboBox x:Name="ThemeBox" DisplayMemberPath="Label" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel"/>
            <Button Content="Save &amp; apply" Style="{StaticResource PrimaryButton}" Click="OnSave"/>
        </StackPanel>
    </StackPanel>
</Window>
